# Produkciniai kintamieji — nukopijuokite šį failą į .env ir užpildykite.
# Reikšmės APP_ID, APP_SECRET, OWNER_UNION_ID, KIMI_* imkite iš savo kūrimo
# aplinkos .env failo (arba Kimi portalo aplikacijos nustatymų).
# VITE_* reikšmės įdedamos į frontend'ą build metu — jos viešos, nesijaudinkite.

APP_ID=UZPILDYKITE
APP_SECRET=UZPILDYKITE

VITE_APP_ID=UZPILDYKITE
VITE_KIMI_AUTH_URL=UZPILDYKITE

KIMI_AUTH_URL=UZPILDYKITE
KIMI_OPEN_URL=UZPILDYKITE
OWNER_UNION_ID=UZPILDYKITE

# Stiprus slaptažodis naujai MySQL duomenų bazei (deploy.sh sugeneruoja automatiškai):
DB_ROOT_PASSWORD=PAKEISKITE_STIPRU_SLAPTAZODZI
